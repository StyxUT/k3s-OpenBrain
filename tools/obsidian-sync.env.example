# Optional environment for launchd-driven Obsidian -> OpenBrain sync.
# Copy to obsidian-sync.env and fill in only if kubectl on this machine
# cannot read the postgres-password secret directly.

OPENBRAIN_DB_PASSWORD=
OPENBRAIN_API_BASE=http://k3s-nodes.home:8000
KUBE_API_SERVER=https://k3s-nodes.home:6443
# EMBEDDING_API_BASE=http://192.168.0.13:11434/v1
